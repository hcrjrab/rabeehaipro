# Rabeeh AI Agent Pro - example environment configuration.
# Copy to `.env` and edit. All variables are prefixed with RABEEH_.

# --- Core runtime ---
RABEEH_ENV=dev
RABEEH_DEBUG=true
RABEEH_HOST=127.0.0.1
RABEEH_PORT=8000
RABEEH_LOG_LEVEL=INFO
RABEEH_LOG_FORMAT=console

# --- Security (REPLACE in production) ---
RABEEH_SECRET_KEY=dev-only-insecure-key-change-me
RABEEH_JWT_SECRET=dev-only-jwt-secret-change-me
RABEEH_AUTH_ADMIN_USERNAME=admin
RABEEH_AUTH_ADMIN_PASSWORD=dev-only-admin-pw-change-me
RABEEH_APPROVAL_LEVEL=destructive

# --- Databases / queues ---
RABEEH_DATABASE_URL=postgresql+psycopg://rabeeh:rabeeh@localhost:5432/rabeeh
RABEEH_REDIS_URL=redis://localhost:6379/0

# --- LLM providers ---
# `mock` boots fully offline; switch to `ollama` once Ollama is running.
RABEEH_DEFAULT_PROVIDER=mock
RABEEH_PREFER_LOCAL=true
RABEEH_OLLAMA_BASE_URL=http://localhost:11434
RABEEH_OLLAMA_DEFAULT_MODEL=qwen2.5:7b
# Leave empty to disable cloud; needed only for fallback/specialised routing.
RABEEH_OPENROUTER_API_KEY=
RABEEH_OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# --- Agents ---
RABEEH_MAX_ORCHESTRATOR_ITERATIONS=20
RABEEH_AGENT_TEMPERATURE=0.2
