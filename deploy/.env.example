# Rabeeh AI - Docker Compose environment
# Copy to .env and edit before running: docker compose up -d

# --- Core runtime ---
RABEEH_ENV=production
RABEEH_DEBUG=false
RABEEH_HOST=0.0.0.0
RABEEH_PORT=8000
RABEEH_LOG_LEVEL=INFO
RABEEH_LOG_FORMAT=json

# --- Security (REPLACE in production) ---
RABEEH_SECRET_KEY=change-me-to-a-random-secret
RABEEH_JWT_SECRET=change-me-to-a-random-jwt-secret
RABEEH_APPROVAL_LEVEL=destructive

# --- LLM providers ---
RABEEH_DEFAULT_PROVIDER=mock
RABEEH_PREFER_LOCAL=true
RABEEH_OLLAMA_BASE_URL=http://ollama:11434
RABEEH_OLLAMA_DEFAULT_MODEL=qwen2.5:7b
RABEEH_OPENROUTER_API_KEY=
RABEEH_OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# --- Agents ---
RABEEH_MAX_ORCHESTRATOR_ITERATIONS=20
RABEEH_AGENT_TEMPERATURE=0.2
